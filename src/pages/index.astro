---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import WhatsAppAssistant from "../components/WhatsAppAssistant.astro";
import Features from "../components/Features.astro";
import Choice from "../components/Choice.astro";
import Comparison from "../components/Comparison.astro";
import Testimonials from "../components/Testimonials.astro";
import Disclaimer from "../components/Disclaimer.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
const isAppAvailable = false; // Cambiar a true cuando la app esté oficialmente disponible
---

<Layout
  title="Conty - Gestiona tu negocio por WhatsApp o App"
  description="La forma más sencilla y rápida de llevar las cuentas de tus negocios. Regístrate por WhatsApp o descarga nuestra App. Controla ventas, gastos y reportes."
  keywords="contabilidad, pymes, gestión de negocios, administración, ventas, gastos, venezuela, emprendimiento, whatsapp assistant, ai assistant"
>
  <Hero isAppAvailable={isAppAvailable} />
  <WhatsAppAssistant />
  <Features />
  <Choice isAppAvailable={isAppAvailable} />
  <Comparison />
  <Testimonials />
  <Disclaimer />
  <Pricing isAppAvailable={isAppAvailable} />
  <FAQ />
  <CTA isAppAvailable={isAppAvailable} />
</Layout>
