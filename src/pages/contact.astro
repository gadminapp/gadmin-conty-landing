---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import CTA from "../components/CTA.astro";
---

<Layout
  title="Contacto - Conty"
  description="¿Tienes dudas sobre Conty? Envíanos un mensaje o contáctanos por email para recibir soporte personalizado para tu negocio."
  keywords="soporte, contacto, ayuda, gadmin conty, email soporte"
>

  <section
    class="flex items-center relative min-h-screen py-20 pt-24 overflow-hidden"
  >
    <!-- Fondos dinámicos -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(80% 60% at 50% 0%, rgba(0, 204, 7, 0.08) 0%, transparent 70%);"
    >
    </div>
    <div
      class="absolute top-1/4 -right-20 w-96 h-96 bg-[#00cc07]/5 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="max-w-6xl mx-auto px-5 relative z-10">
      <div class="grid lg:grid-cols-2 gap-16 items-start">
        <!-- Columna Izquierda: Info de contacto -->
        <div class="animate-fade-in-up">
          <h1
            class="text-4xl sm:text-6xl font-bold text-[#082109] leading-tight mb-8"
          >
            ¿Cómo podemos <span class="text-[#00cc07]">ayudarte?</span>
          </h1>
          <p class="text-xl text-[#082109]/60 leading-relaxed mb-12 max-w-lg">
            Estamos aquí para resolver tus dudas y ayudarte a llevar la gestión
            de tu negocio al siguiente nivel. Elige el canal que prefieras.
          </p>

          <div class="space-y-6">
            <!-- Card Email -->
            <div
              class="group p-6 bg-white border border-[#082109]/5 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.02)] hover:shadow-[0_8px_30px_rgba(0,204,7,0.1)] transition-all duration-300"
            >
              <div class="flex items-center gap-5">
                <div
                  class="w-14 h-14 bg-[#00cc07]/10 rounded-2xl flex items-center justify-center group-hover:bg-[#00cc07] group-hover:text-white transition-colors"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                  </svg>
                </div>
                <div>
                  <p
                    class="text-sm font-semibold text-[#082109]/40 uppercase tracking-wider"
                  >
                    Escríbenos
                  </p>
                  <a
                    href="mailto:contacto@gadminconty.com"
                    class="text-lg font-bold text-[#082109] hover:text-[#00cc07] transition-colors"
                  >
                    contacto@gadminconty.com
                  </a>
                </div>
              </div>
            </div>

            <!-- Card Social -->
            <div
              class="group p-6 bg-white border border-[#082109]/5 rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.02)] hover:shadow-[0_8px_30px_rgba(0,204,7,0.1)] transition-all duration-300"
            >
              <div class="flex items-center gap-5">
                <div
                  class="w-14 h-14 bg-[#00cc07]/10 rounded-2xl flex items-center justify-center group-hover:bg-[#00cc07] group-hover:text-white transition-colors"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path
                      d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                    ></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <p
                    class="text-sm font-semibold text-[#082109]/40 uppercase tracking-wider mb-2"
                  >
                    Síguenos
                  </p>
                  <div class="flex gap-4">
                    <a
                      href="https://www.instagram.com/gadmin.app/"
                      target="_blank"
                      aria-label="Instagram"
                      class="w-10 h-10 rounded-xl bg-[#082109]/5 flex items-center justify-center text-[#082109]/75 hover:bg-[#00CC07] hover:text-white transition-all"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <rect width="20" height="20" x="2" y="2" rx="5" ry="5"
                        ></rect>
                        <path
                          d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                        ></path>
                        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                      </svg>
                    </a>
                    <a
                      href="https://www.tiktok.com/@gadmin.app"
                      target="_blank"
                      aria-label="TikTok"
                      class="w-10 h-10 rounded-xl bg-[#082109]/5 flex items-center justify-center text-[#082109]/75 hover:bg-[#00CC07] hover:text-white transition-all"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
                      </svg>
                    </a>
                    <a
                      href="https://www.linkedin.com/company/gadminapp"
                      target="_blank"
                      aria-label="LinkedIn"
                      class="w-10 h-10 rounded-xl bg-[#082109]/5 flex items-center justify-center text-[#082109]/75 hover:bg-[#00CC07] hover:text-white transition-all"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path
                          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                        ></path>
                        <rect width="4" height="12" x="2" y="9"></rect>
                        <circle cx="4" cy="4" r="2"></circle>
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Columna Derecha: Formulario -->
        <div class="animate-fade-in-up delay-100">
          <div
            class="p-8 sm:p-12 bg-white rounded-[2.5rem] shadow-[0_20px_50px_rgba(8,33,9,0.05)] border border-[#082109]/5 relative"
          >
            <h3 class="text-2xl font-bold text-[#082109] mb-8">
              Envíanos un mensaje
            </h3>
            <form class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label
                    for="name"
                    class="text-sm font-medium text-[#082109]/60 ml-1"
                    >Nombre</label
                  >
                  <input
                    type="text"
                    id="name"
                    placeholder="Tu nombre"
                    class="w-full px-6 py-4 bg-[#082109]/5 border-none rounded-2xl focus:ring-2 focus:ring-[#00cc07] transition-all outline-none text-[#082109] placeholder:text-[#082109]/30"
                  />
                </div>
                <div class="space-y-2">
                  <label
                    for="email"
                    class="text-sm font-medium text-[#082109]/60 ml-1"
                    >Email</label
                  >
                  <input
                    type="email"
                    id="email"
                    placeholder="ejemplo@correo.com"
                    class="w-full px-6 py-4 bg-[#082109]/5 border-none rounded-2xl focus:ring-2 focus:ring-[#00cc07] transition-all outline-none text-[#082109] placeholder:text-[#082109]/30"
                  />
                </div>
              </div>
              <div class="space-y-2">
                <label
                  for="subject"
                  class="text-sm font-medium text-[#082109]/60 ml-1"
                  >Asunto</label
                >
                <input
                  type="text"
                  id="subject"
                  placeholder="¿En qué podemos ayudarte?"
                  class="w-full px-6 py-4 bg-[#082109]/5 border-none rounded-2xl focus:ring-2 focus:ring-[#00cc07] transition-all outline-none text-[#082109] placeholder:text-[#082109]/30"
                />
              </div>
              <div class="space-y-2">
                <label
                  for="message"
                  class="text-sm font-medium text-[#082109]/60 ml-1"
                  >Mensaje</label
                >
                <textarea
                  id="message"
                  rows="4"
                  placeholder="Escribe aquí tu mensaje..."
                  class="w-full px-6 py-4 bg-[#082109]/5 border-none rounded-2xl focus:ring-2 focus:ring-[#00cc07] transition-all outline-none text-[#082109] placeholder:text-[#082109]/30 resize-none"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full py-4 bg-[#00cc07] text-[#082109] font-bold rounded-2xl shadow-xl shadow-[#00cc07]/20 hover:bg-[#00b306] hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-3"
              >
                <span>Enviar mensaje</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="22" y1="2" x2="11" y2="13"></line>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>
