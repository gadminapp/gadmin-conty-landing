---
import contyLogo from "../assets/logo-no-bg.png";
---

<header
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  role="banner"
>
  <nav
    class="max-w-6xl mx-auto px-5 h-16 flex items-center justify-between"
    role="navigation"
  >
    <a href="/" class="flex items-center gap-2">
      <img src={contyLogo.src} width="40" height="40" alt="Gadmin Conty Logo" />
      <span class="font-bold text-xl text-[#082109]">Conty</span>
      <span class="text-xs text-[#082109]/60 font-medium hidden sm:block"
        >de Gadmin</span
      >
    </a>
    <div class="hidden md:flex items-center gap-6">
      <a
        href="#asistente"
        class="text-sm font-medium text-[#04910a] hover:text-[#14b81a] transition-colors"
        >Asistente IA
      </a>
      <a
        href="#funciones"
        class="text-sm font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
        >Funciones
      </a>
      <a
        href="#testimonios"
        class="text-sm font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
        >Testimonios
      </a>
      <a
        href="#precios"
        class="text-sm font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
        >Precios
      </a>
      <a
        href="#faq"
        class="text-sm font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
        >FAQ
      </a>
      <a
        href="https://wa.me/12013538852?text=%C2%A1Hola!%20Quiero%20tener%20mi%20asistente."
        class="bg-[#14b81a] text-[#082109] text-sm font-semibold px-5 py-2.5 rounded-full hover:brightness-110 transition-all shadow-md animate-pulse-brand"
        >Probar Gratis
      </a>
    </div>
    <button
      id="menu-btn"
      class="md:hidden p-2 text-[#082109]"
      aria-label="Menu"
    >
      <svg
        id="menu-icon"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-menu"
        aria-hidden="true"
      >
        <path d="M4 5h16"></path>
        <path d="M4 12h16"></path>
        <path d="M4 19h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="hidden"
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-x"
        aria-hidden="true"
      >
        <path d="M18 6 6 18"></path>
        <path d="M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white/98 backdrop-blur-md border-t border-gray-100 flex-col p-6 gap-5 shadow-xl transition-all duration-300 origin-top"
  >
    <a
      href="#asistente"
      class="mobile-link text-lg font-medium text-[#04910a] hover:text-[#14b81a] transition-colors"
      >Asistente IA
    </a>
    <a
      href="#funciones"
      class="mobile-link text-lg font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
      >Funciones
    </a>
    <a
      href="#testimonios"
      class="mobile-link text-lg font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
      >Testimonios
    </a>
    <a
      href="#precios"
      class="mobile-link text-lg font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
      >Precios
    </a>
    <a
      href="#faq"
      class="mobile-link text-lg font-medium text-[#082109]/70 hover:text-[#14b81a] transition-colors"
      >FAQ
    </a>
    <hr class="border-[#082109]/5" />
    <a
      href="https://wa.me/12013538852?text=%C2%A1Hola!%20Quiero%20tener%20mi%20asistente."
      class="mobile-link bg-[#14b81a] text-[#082109] text-center font-bold py-4 rounded-2xl hover:brightness-110 transition-all shadow-md"
      >Probar Gratis Ahora
    </a>
  </div>
</header>

<script>
  const onScroll = ["bg-white/95", "backdrop-blur-md", "shadow-sm"];
  const offScroll = ["bg-transparent"];
  const header = document.querySelector("header");
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  let isMenuOpen = false;

  const toggleMenu = () => {
    isMenuOpen = !isMenuOpen;

    if (isMenuOpen) {
      mobileMenu?.classList.remove("hidden");
      mobileMenu?.classList.add("flex");
      menuIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      header?.classList.add(...onScroll);
      header?.classList.remove(...offScroll);
      document.body.style.overflow = "hidden"; // Prevent scroll
    } else {
      mobileMenu?.classList.add("hidden");
      mobileMenu?.classList.remove("flex");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      document.body.style.overflow = ""; // Enable scroll
      updateHeader();
    }
  };

  const updateHeader = () => {
    if (isMenuOpen) return; // Keep scroll classes if menu is open

    if (window.scrollY > 0) {
      header?.classList.add(...onScroll);
      header?.classList.remove(...offScroll);
    } else {
      header?.classList.remove(...onScroll);
      header?.classList.add(...offScroll);
    }
  };

  menuBtn?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  window.addEventListener("scroll", updateHeader);
  // Initial check
  updateHeader();
</script>

<style>
  @keyframes pulse-brand {
    0% {
      box-shadow: 0 0 0 0 rgba(0, 204, 7, 0.4);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(0, 204, 7, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(0, 204, 7, 0);
    }
  }

  .animate-pulse-brand {
    animation: pulse-brand 2s infinite;
  }
</style>
