---
import contyLogo from "../assets/logo-no-bg.png";
interface Message {
  type: string;
  time: string;
  text?: string;
  isAudio?: boolean;
}

interface Props {
  version?: string;
  messages?: Message[];
}

const { version = "default", messages = null } = Astro.props;

const DEFAULT_MESSAGES = [
  { type: "user", text: "Vendí 1 Hamburguesa $3.2", time: "10:45 AM" },
  {
    type: "bot",
    text: "¡Anotado! ✅ <br/>Venta de Hamburguesa por <b>$3.2</b>.<br/><br/>Estás construyendo algo increíble, paso a paso. 🧱",
    time: "10:45 AM",
  },
  { type: "user", isAudio: true, time: "10:47 AM" },
  {
    type: "bot",
    text: "¡Entendido! Registré un gasto de <b>$3.00</b> en Papeles.<br/><br/>Invertir sabiamente es clave para un crecimiento sostenible. 🌱",
    time: "10:47 AM",
  },
  { type: "user", text: "¿Cuánto vendí hoy?", time: "11:02 AM" },
  {
    type: "bot",
    text: "Hoy llevas <b>$48.50</b> en ventas. Vas muy bien, ¡Estás al 85% de tu meta diaria! 🚀",
    time: "11:02 AM",
  },
];

const messagesToUse = messages || DEFAULT_MESSAGES;
---

<div
  id={`mockup-${version}`}
  data-messages={JSON.stringify(messagesToUse)}
  class="whatsapp-mockup relative mx-auto w-full max-w-[100%] md:max-w-[320px] h-full bg-[#E5DDD5] rounded-[2.5rem] border-[8px] border-[#082109] shadow-2xl overflow-hidden aspect-[9/18]"
>
  <!-- Header -->
  <div class="bg-[#075E54] p-4 pt-8 flex items-center gap-3">
    <div
      class="w-10 h-10 rounded-full bg-white flex items-center justify-center"
    >
      <img src={contyLogo.src} alt="Conty AI" class="w-8 h-8" />
    </div>
    <div class="text-left">
      <p class="text-white font-bold text-sm">Conty</p>
      <p class="text-white/70 text-[10px]">En línea</p>
    </div>
  </div>

  <!-- Messages Area -->
  <div
    class="messages-container p-4 space-y-4 h-[calc(100%-80px)] overflow-y-auto"
  >
    {
      messagesToUse[0] && (
        <div
          class={`whatsapp-message visible flex ${messagesToUse[0].type === "user" ? "justify-end" : "justify-start"} w-full`}
        >
          <div
            class={`${messagesToUse[0].type === "user" ? "bg-[#DCF8C6]" : "bg-white"} p-3 rounded-lg ${messagesToUse[0].type === "user" ? "rounded-tr-none" : "rounded-tl-none"} shadow-sm max-w-[85%]`}
          >
            {messagesToUse[0].isAudio ? (
              <div class="flex items-center gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-blue-500"
                >
                  <path d="M2 10v3" />
                  <path d="M6 6v11" />
                  <path d="M10 3v18" />
                  <path d="M14 8v7" />
                  <path d="M18 5v13" />
                  <path d="M22 10v3" />
                </svg>
                <p class="text-[10px] text-gray-600">0:05</p>
              </div>
            ) : (
              <p
                class="text-xs text-gray-800"
                set:html={messagesToUse[0].text || ""}
              />
            )}
            <p class="text-[8px] text-gray-500 text-right mt-1">
              {messagesToUse[0].time}
            </p>
          </div>
        </div>
      )
    }

    <!-- Typing Indicator -->
    <div
      class="typing-indicator flex justify-start opacity-0 transition-opacity duration-300"
    >
      <div
        class="bg-white p-3 rounded-lg rounded-tl-none shadow-sm flex gap-1 items-center"
      >
        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce"
        ></span>
        <span
          class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce [animation-delay:0.2s]"
        ></span>
        <span
          class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce [animation-delay:0.4s]"
        ></span>
      </div>
    </div>
  </div>
</div>

<style>
  .messages-container::-webkit-scrollbar {
    width: 0px;
  }

  :global(.whatsapp-message) {
    opacity: 0;
    transform: translateY(10px) scale(0.95);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  :global(.whatsapp-message.visible) {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  interface Message {
    type: string;
    time: string;
    text?: string;
    isAudio?: boolean;
  }

  function createMessageHTML(msg: Message) {
    const isUser = msg.type === "user";
    const alignClass = isUser ? "justify-end" : "justify-start";
    const bgClass = isUser ? "bg-[#DCF8C6]" : "bg-white";
    const roundClass = isUser ? "rounded-tr-none" : "rounded-tl-none";

    let content = `<p class="text-xs text-gray-800">${msg.text || ""}</p>`;

    if (msg.isAudio) {
      content = `
        <div class="flex items-center gap-2">
           <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M2 10v3"></path><path d="M6 6v11"></path><path d="M10 3v18"></path><path d="M14 8v7"></path><path d="M18 5v13"></path><path d="M22 10v3"></path></svg>
           <p class="text-[10px] text-gray-600">0:05</p>
        </div>
      `;
    }

    return `
      <div class="whatsapp-message flex ${alignClass} w-full">
        <div class="${bgClass} p-3 rounded-lg ${roundClass} shadow-sm max-w-[85%]">
          ${content}
          <p class="text-[8px] text-gray-500 text-right mt-1">${msg.time}</p>
        </div>
      </div>
    `;
  }

  async function startMessages(container: HTMLElement) {
    const messagesArea = container.querySelector(".messages-container")!;
    const typing = container.querySelector(".typing-indicator")!;
    const messagesData = container.getAttribute("data-messages");
    if (!messagesData) return;

    const messages: Message[] = JSON.parse(messagesData);
    const messagesToAnimate = messages.slice(1);

    for (const msg of messagesToAnimate) {
      // 1. Initial delay for each step
      await new Promise((r) => setTimeout(r, msg.type === "user" ? 2000 : 200));

      // 2. Typing indicator for bot
      if (msg.type === "bot") {
        typing.classList.add("opacity-100");
        messagesArea.scrollTo({
          top: messagesArea.scrollHeight,
          behavior: "smooth",
        });
        await new Promise((r) => setTimeout(r, 1500));
        typing.classList.remove("opacity-100");
        await new Promise((r) => setTimeout(r, 300));
      }

      // 3. Create and inject message
      const msgDiv = document.createElement("div");
      msgDiv.innerHTML = createMessageHTML(msg);
      const element = msgDiv.firstElementChild!;
      messagesArea.insertBefore(element, typing);

      // 4. Animate entry
      requestAnimationFrame(() => {
        element.classList.add("visible");
        messagesArea.scrollTo({
          top: messagesArea.scrollHeight,
          behavior: "smooth",
        });
      });
    }
  }

  function init() {
    const mockups = document.querySelectorAll(".whatsapp-mockup");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startMessages(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );

    mockups.forEach((m) => observer.observe(m));
  }

  // Run on page load and after Astro view transitions
  init();
  document.addEventListener("astro:after-swap", init);
</script>
