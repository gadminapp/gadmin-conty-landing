<section id="precios" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-12 animate-fade-in-up">
      <span
        class="inline-block text-[#00CC07] text-sm font-semibold uppercase tracking-widest mb-3"
        >Precios</span
      >
      <h2 class="text-3xl sm:text-4xl font-bold text-[#082109] mb-4">
        Gratis para siempre, <span class="text-[#00CC07]"
          >premium si quieres más</span
        >
      </h2>
      <p class="text-gray-500 text-base max-w-lg mx-auto">
        Usa Conty sin pagar nada. Si necesitas funciones avanzadas, activa el
        plan Pro.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <!-- Plan Gratuito -->
      <div class="animate-fade-in-up delay-100">
        <div
          class="relative bg-white border-2 border-gray-200 rounded-3xl p-8 h-full flex flex-col"
        >
          <div class="flex items-center gap-2 mb-6">
            <div
              class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-heart text-[#00CC07]"
                aria-hidden="true"
                ><path
                  d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                ></path></svg
              >
            </div>
            <span class="text-[#082109] font-bold text-lg">Plan Gratuito</span>
          </div>

          <div class="mb-2">
            <div class="flex items-end gap-2">
              <span class="text-5xl font-bold text-[#082109]">$0</span>
              <span class="text-gray-400 mb-2 text-sm">/ siempre</span>
            </div>
            <p class="text-gray-500 text-sm mt-1">
              Todo lo esencial para llevar tu negocio
            </p>
          </div>

          <ul class="space-y-3 my-8 flex-1">
            {
              [
                "Registro ilimitado de ventas",
                "Registro ilimitado de gastos",
                "Meta semanal",
                "Funciona offline",
                "Gráficos y reportes",
                "Múltiples negocios",
                "Soporte por WhatsApp",
              ].map((feat) => (
                <li class="flex items-center gap-3">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-[#00CC07] shrink-0"
                  >
                    <>
                      <path d="M21.801 10A10 10 0 1 1 17 3.335" />
                      <path d="m9 11 3 3L22 4" />
                    </>
                  </svg>
                  <span class="text-[#082109]/80 text-sm">{feat}</span>
                </li>
              ))
            }
          </ul>

          <a
            href="https://play.google.com/store"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center bg-[#082109] text-white font-bold py-4 rounded-2xl hover:bg-[#082109]/90 transition-all"
          >
            Descargar gratis
          </a>
        </div>
      </div>

      <!-- Plan Premium -->
      <div class="animate-fade-in-up delay-200">
        <div
          class="relative bg-[#082109] rounded-3xl p-8 shadow-2xl overflow-hidden h-full flex flex-col"
        >
          <div
            class="absolute top-5 right-5 bg-[#00CC07] text-[#082109] text-xs font-bold px-3 py-1 rounded-full z-20"
          >
            Recomendado
          </div>

          <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(80% 60% at 50% 0%, rgba(0, 204, 7, 0.15) 0%, transparent 70%);"
          >
          </div>

          <div class="relative z-10 flex flex-col h-full">
            <div class="flex items-center gap-2 mb-6">
              <div
                class="w-9 h-9 rounded-xl bg-[#00CC07] flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-sparkles text-[#082109]"
                  aria-hidden="true"
                  ><path
                    d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"
                  ></path><path d="M20 3v4"></path><path d="M22 5h-4"
                  ></path></svg
                >
              </div>
              <span id="plan-title" class="text-white font-bold text-lg"
                >Plan Mensual</span
              >
            </div>

            <div class="mb-2">
              <div class="flex items-end gap-2">
                <span id="plan-price" class="text-5xl font-bold text-white"
                  >$9.99</span
                >
                <span id="plan-period" class="text-white/75 mb-2 text-sm"
                  >/ mes</span
                >
              </div>
              <p id="plan-desc" class="text-white/75 text-sm mt-1">
                O paga anual y ahorra 2 meses
              </p>
            </div>

            <div
              class="inline-flex items-center gap-3 mt-4 mb-6 bg-white/10 rounded-full p-1.5 self-start"
            >
              <button
                id="btn-mensual"
                class="pricing-tab px-4 py-1.5 rounded-full text-xs font-semibold transition-all bg-white text-[#082109] shadow-sm"
              >
                Mensual
              </button>
              <button
                id="btn-anual"
                class="pricing-tab px-4 py-1.5 rounded-full text-xs font-semibold transition-all flex items-center gap-1.5 text-white/60"
              >
                Anual
                <span
                  class="bg-[#00CC07] text-[#082109] text-[10px] px-1.5 py-0.5 rounded-full font-bold"
                  >-17%</span
                >
              </button>
            </div>

            <p
              class="text-white/50 text-xs uppercase tracking-wider font-semibold mb-3"
            >
              Todo lo gratuito, más:
            </p>

            <ul class="space-y-3 mb-8 flex-1">
              {
                [
                  "Predicciones inteligentes de ventas",
                  "Cargar gastos desde ticket/factura",
                  "Gestión de inventario y stock",
                  "Exportar reportes avanzados",
                  "Actualizaciones prioritarias",
                ].map((feat) => (
                  <li class="flex items-center gap-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-[#00CC07] shrink-0"
                    >
                      <>
                        <path d="M21.801 10A10 10 0 1 1 17 3.335" />
                        <path d="m9 11 3 3L22 4" />
                      </>
                    </svg>
                    <span class="text-white/80 text-sm">{feat}</span>
                  </li>
                ))
              }
            </ul>

            <a
              href="#"
              class="block w-full text-center bg-[#00CC07] text-[#082109] font-bold py-4 rounded-2xl hover:brightness-110 transition-all shadow-lg shadow-[#00CC07]/20"
            >
              Activar Plan Premium
            </a>
            <p class="text-white/75 text-xs text-center mt-4">
              Cancela cuando quieras. Sin compromisos.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-8 bg-[#00CC07]/5 border border-[#00CC07]/10 rounded-2xl p-4 text-center max-w-3xl mx-auto"
    >
      <p class="text-[#082109]/70 text-sm">
        <span class="font-semibold text-[#082109]"
          >¿Por qué ofrecer un plan de pago?</span
        > Porque las funciones premium requieren inteligencia artificial y servidores
        avanzados. Tu suscripción nos permite seguir innovando y brindarte la mejor
        experiencia.
      </p>
    </div>
  </div>
</section>

<script>
  const btnMensual = document.getElementById("btn-mensual");
  const btnAnual = document.getElementById("btn-anual");
  const planTitle = document.getElementById("plan-title");
  const planPrice = document.getElementById("plan-price");
  const planPeriod = document.getElementById("plan-period");
  const planDesc = document.getElementById("plan-desc");

  function setPricing(mode: "yearly" | "monthly") {
    if (
      !btnAnual ||
      !btnMensual ||
      !planTitle ||
      !planPrice ||
      !planPeriod ||
      !planDesc
    )
      return;

    if (mode === "yearly") {
      btnAnual.classList.add("bg-white", "text-[#082109]", "shadow-sm");
      btnAnual.classList.remove("text-white/60");
      btnMensual.classList.remove("bg-white", "text-[#082109]", "shadow-sm");
      btnMensual.classList.add("text-white/60");

      planTitle.textContent = "Plan Anual";
      planPrice.textContent = "$99.99";
      planPeriod.textContent = "/ año";
      planDesc.innerHTML =
        '<span class="text-[#00CC07] font-medium">Equivale a $8.33/mes (2 meses gratis)</span>';
    } else {
      btnMensual.classList.add("bg-white", "text-[#082109]", "shadow-sm");
      btnMensual.classList.remove("text-white/60");
      btnAnual.classList.remove("bg-white", "text-[#082109]", "shadow-sm");
      btnAnual.classList.add("text-white/60");

      planTitle.textContent = "Plan Mensual";
      planPrice.textContent = "$9.99";
      planPeriod.textContent = "/ mes";
      planDesc.textContent = "O paga anual y ahorra 2 meses";
    }
  }

  btnMensual?.addEventListener("click", () => setPricing("monthly"));
  btnAnual?.addEventListener("click", () => setPricing("yearly"));
</script>
