---
const { isAppAvailable = false } = Astro.props;
---

<section id="precios" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-12 animate-fade-in-up">
      <span
        class="inline-block text-[#14b81a] text-sm font-semibold uppercase tracking-widest mb-3"
        >Precios</span
      >
      <h2 class="text-3xl sm:text-4xl font-bold text-[#082109] mb-4">
        Gratis para siempre, <span class="text-[#14b81a]"
          >premium si quieres más</span
        >
      </h2>
      <p class="text-gray-500 text-base max-w-lg mx-auto">
        Usa Conty sin pagar nada. Si necesitas funciones avanzadas, activa el
        plan Pro.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      <!-- Plan Gratuito -->
      <div class="animate-fade-in-up delay-100">
        <div
          class="relative bg-white border-2 border-gray-200 rounded-3xl p-8 h-full flex flex-col"
        >
          <div class="flex items-center gap-2 mb-6">
            <div
              class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-gift-icon lucide-gift text-[#08210990]"
                ><path d="M12 7v14"></path><path
                  d="M20 11v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8"></path><path
                  d="M7.5 7a1 1 0 0 1 0-5A4.8 8 0 0 1 12 7a4.8 8 0 0 1 4.5-5 1 1 0 0 1 0 5"
                ></path><rect x="3" y="7" width="18" height="4" rx="1"
                ></rect></svg
              >
            </div>
            <span class="text-[#082109] font-bold text-lg">Plan Gratuito</span>
          </div>

          <div class="mb-2">
            <div class="flex items-end gap-2">
              <span class="text-5xl font-bold text-[#082109]">$0</span>
              <span class="text-gray-400 mb-2 text-sm">/ siempre</span>
            </div>
            <p class="text-gray-500 text-sm mt-1">
              Todo lo esencial para empezar a usar Conty
            </p>
          </div>

          <ul class="space-y-3 my-8 flex-1">
            {
              [
                "10 consultas Asistente IA por día",
                "Registro ilimitado de ventas",
                "Registro ilimitado de gastos",
                "Hasta 1 miembro por negocio",
                "Define tu meta semanal",
                "Gráficos y reportes",
                "Exportación a Excel",
              ].map((feat) => (
                <li class="flex items-center gap-3">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-[#14b81a] shrink-0"
                  >
                    <>
                      <path d="M21.801 10A10 10 0 1 1 17 3.335" />
                      <path d="m9 11 3 3L22 4" />
                    </>
                  </svg>
                  <span class="text-[#082109]/80 text-sm">{feat}</span>
                </li>
              ))
            }
          </ul>

          <a
            href={isAppAvailable
              ? "https://play.google.com/store/apps/details?id=com.gadmin.conty"
              : "https://wa.me/12013538852?text=%C2%A1Hola!%20Quiero%20probar%20Conty."}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center bg-[#082109] text-white font-bold py-4 rounded-2xl hover:bg-[#082109]/90 transition-all"
          >
            Empezar
          </a>
        </div>
      </div>

      <!-- Plan Premium -->
      <div class="animate-fade-in-up delay-200">
        <div
          class="relative bg-[#082109] rounded-3xl p-8 shadow-2xl overflow-hidden h-full flex flex-col"
        >
          <div
            class="absolute top-5 right-5 bg-[#1ec924] text-[#082109] text-xs font-bold px-3 py-1 rounded-full z-20"
          >
            Recomendado
          </div>

          <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(80% 60% at 50% 0%, rgba(0, 204, 7, 0.15) 0%, transparent 70%);"
          >
          </div>

          <div class="relative z-10 flex flex-col h-full">
            <div class="flex items-center gap-2 mb-6">
              <div
                class="w-9 h-9 rounded-xl bg-[#1ec924] flex items-center justify-center"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-gem-icon lucide-gem text-[#082109]"
                  ><path d="M10.5 3 8 9l4 13 4-13-2.5-6"></path><path
                    d="M17 3a2 2 0 0 1 1.6.8l3 4a2 2 0 0 1 .013 2.382l-7.99 10.986a2 2 0 0 1-3.247 0l-7.99-10.986A2 2 0 0 1 2.4 7.8l2.998-3.997A2 2 0 0 1 7 3z"
                  ></path><path d="M2 9h20"></path></svg
                >
              </div>
              <span id="plan-title" class="text-white font-bold text-lg"
                >Plan Premium</span
              >
            </div>

            <div class="mb-2">
              <div class="flex items-end gap-2">
                <span id="plan-price" class="text-5xl font-bold text-white"
                  >$19.99</span
                >
                <span id="plan-period" class="text-white/75 mb-2 text-sm"
                  >/ mes</span
                >
              </div>
              <p id="plan-desc" class="text-white/75 text-sm mt-1">
                O paga anualmente y ahorra 2 meses
              </p>
            </div>

            <div
              class="inline-flex items-center gap-3 mt-4 mb-6 bg-white/10 rounded-full p-1.5 self-start"
            >
              <button
                id="btn-mensual"
                class="pricing-tab px-4 py-1.5 rounded-full text-xs font-semibold transition-all bg-white text-[#082109] shadow-sm"
              >
                Mensual
              </button>
              <button
                id="btn-anual"
                class="pricing-tab px-4 py-1.5 rounded-full text-xs font-semibold transition-all flex items-center gap-1.5 text-white/60"
              >
                Anual
                <span
                  class="bg-[#1ec924] text-[#082109] text-[10px] px-1.5 py-0.5 rounded-full font-bold"
                  >-17%</span
                >
              </button>
            </div>

            <p
              class="text-white/50 text-xs uppercase tracking-wider font-semibold mb-3"
            >
              Todo lo gratuito, más:
            </p>

            <ul class="space-y-3 mb-8 flex-1">
              {
                [
                  {
                    text: "Hasta 3,000 consultas Asistente IA",
                    sub: "+$3 por cada 1,000 adicionales",
                  },
                  { text: "Hasta 10 miembros por negocio" },
                  // { text: "Hasta 10 miembros por negocio" },
                  { text: "Predicciones inteligentes" },
                  { text: "Cargar gastos desde fotos (recibos/tickets)" },
                ].map((item) => (
                  <li class="flex items-start gap-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-[#1ec924] shrink-0 mt-0.5"
                    >
                      <>
                        <path d="M21.801 10A10 10 0 1 1 17 3.335" />
                        <path d="m9 11 3 3L22 4" />
                      </>
                    </svg>
                    <span class="text-white/80 text-sm">
                      {item.text}
                      {item.sub && (
                        <>
                          <br />
                          <small class="text-white/60 text-[11px] leading-tight">
                            ({item.sub})
                          </small>
                        </>
                      )}
                    </span>
                  </li>
                ))
              }
            </ul>

            <p class="text-white/75 text-xs text-center mb-4">
              Cancela cuando quieras. Sin compromisos.
            </p>
            <a
              href={isAppAvailable
                ? "#"
                : "https://wa.me/12013538852?text=%C2%A1Hola!%20Quiero%20informaci%C3%B3n%20sobre%20el%20Plan%20Premium."}
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full text-center bg-[#1ec924] text-[#082109] font-bold py-4 rounded-2xl hover:brightness-110 transition-all shadow-lg shadow-[#1ec924]/20"
            >
              Empezar
            </a>
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-8 bg-[#14b81a]/5 border border-[#14b81a]/10 rounded-2xl p-4 text-center max-w-3xl mx-auto"
    >
      <p class="text-[#082109]/70 text-sm">
        <span class="font-semibold text-[#082109]">Puedes empezar gratis,</span> cuando
        experimentes que Conty te ahorra más de 21 horas por semana, puedes pasarte
        al Premium para tener aún más.
      </p>
    </div>
  </div>
</section>

<script>
  const btnMensual = document.getElementById("btn-mensual");
  const btnAnual = document.getElementById("btn-anual");
  const planPrice = document.getElementById("plan-price");
  const planPeriod = document.getElementById("plan-period");
  const planDesc = document.getElementById("plan-desc");

  function setPricing(mode: "yearly" | "monthly") {
    if (!btnAnual || !btnMensual || !planPrice || !planPeriod || !planDesc)
      return;

    if (mode === "yearly") {
      btnAnual.classList.add("bg-white", "text-[#082109]", "shadow-sm");
      btnAnual.classList.remove("text-white/60");
      btnMensual.classList.remove("bg-white", "text-[#082109]", "shadow-sm");
      btnMensual.classList.add("text-white/60");

      planPrice.textContent = "$199.99";
      planPeriod.textContent = "/ año";
      planDesc.innerHTML =
        '<span class="text-[#14b81a] font-medium">Equivale a $16.67/mes (2 meses gratis)</span>';
    } else {
      btnMensual.classList.add("bg-white", "text-[#082109]", "shadow-sm");
      btnMensual.classList.remove("text-white/60");
      btnAnual.classList.remove("bg-white", "text-[#082109]", "shadow-sm");
      btnAnual.classList.add("text-white/60");

      planPrice.textContent = "$19.99";
      planPeriod.textContent = "/ mes";
      planDesc.textContent = "O paga anualmente y ahorra 2 meses";
    }
  }

  btnMensual?.addEventListener("click", () => setPricing("monthly"));
  btnAnual?.addEventListener("click", () => setPricing("yearly"));
</script>
