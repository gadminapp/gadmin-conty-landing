---
import contyLogo from "../assets/logo-dark-no-bg.png";
---

<footer class="bg-[#082109] border-t border-white/5 py-10">
  <div class="max-w-6xl mx-auto px-5">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <img
          src={contyLogo.src}
          width="40"
          height="40"
          alt="Gadmin Conty Logo"
        /><span class="text-[#00CC07] font-bold">Conty</span><span
          class="text-white/40 text-sm"
          >· Un producto de <a
            href="https://gadmin.app"
            target="_blank"
            class="text-[#00CC07]/50 hover:text-[#00CC07] transition-colors"
            >Gadmin</a
          ></span
        >
      </div><div class="flex gap-6 text-sm text-white/40">
        <a href="/privacy" class="hover:text-[#00CC07] transition-colors"
          >Privacidad</a
        ><a href="/terms" class="hover:text-[#00CC07] transition-colors"
          >Términos</a
        ><a href="/contact" class="hover:text-[#00CC07] transition-colors"
          >Contacto</a
        >
      </div><div class="flex gap-4">
        <a
          href="https://www.instagram.com/gadmin.app/"
          target="_blank"
          aria-label="Instagram"
          class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-white/40 hover:bg-[#00CC07] hover:text-white transition-all"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a
          href="https://www.tiktok.com/@gadmin.app"
          target="_blank"
          aria-label="TikTok"
          class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-white/40 hover:bg-[#00CC07] hover:text-white transition-all"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/company/gadminapp"
          target="_blank"
          aria-label="LinkedIn"
          class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-white/40 hover:bg-[#00CC07] hover:text-white transition-all"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
    </div><div class="mt-8 pt-6 border-t border-white/5 text-center">
      <p class="text-white/20 text-xs">
        © 2026 Gadmin. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
