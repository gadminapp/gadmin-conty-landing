---
import contyLogo from "../assets/logo-dark-no-bg.png";
---

<footer class="bg-[#082109] border-t border-white/5 py-10">
  <div class="max-w-6xl mx-auto px-5">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2">
        <img
          src={contyLogo.src}
          width="40"
          height="40"
          alt="Gadmin Conty Logo"
        /><span class="text-[#00CC07] font-bold">Conty</span><span
          class="text-white/40 text-sm">· Un producto de Gadmin</span
        >
      </div><div class="flex gap-6 text-sm text-white/40">
        <a href="#" class="hover:text-[#00CC07] transition-colors">Privacidad</a
        ><a href="#" class="hover:text-[#00CC07] transition-colors">Términos</a
        ><a href="#" class="hover:text-[#00CC07] transition-colors">Contacto</a>
      </div><div class="flex gap-4">
        <a
          href="#"
          class="w-9 h-9 rounded-xl bg-white/5 flex items-center justify-center text-white/40 hover:bg-[#00CC07] hover:text-white transition-all text-xs font-bold"
          >IG</a
        ><a
          href="#"
          class="w-9 h-9 rounded-xl bg-white/5 flex items-center justify-center text-white/40 hover:bg-[#00CC07] hover:text-white transition-all text-xs font-bold"
          >FB</a
        ><a
          href="#"
          class="w-9 h-9 rounded-xl bg-white/5 flex items-center justify-center text-white/40 hover:bg-[#00CC07] hover:text-white transition-all text-xs font-bold"
          >TW</a
        >
      </div>
    </div><div class="mt-8 pt-6 border-t border-white/5 text-center">
      <p class="text-white/20 text-xs">
        © 2026 Gadmin. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
