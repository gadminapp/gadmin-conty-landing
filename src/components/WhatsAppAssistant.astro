---
import contyLogo from "../assets/logo-no-bg.png";
---

<section id="asistente" class="py-24 bg-gray-50 overflow-hidden">
  <div class="max-w-6xl mx-auto px-5">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <div class="flex-1 animate-fade-in-left">
        <div class="inline-flex items-center gap-2 bg-[#00CC07]/10 text-[#00CC07] text-sm font-bold px-4 py-1.5 rounded-full mb-6">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.438 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
          </svg>
          Nuevo: Asistente WhatsApp
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-[#082109] mb-6 leading-tight">
          Tu contabilidad, tan fácil como <span class="text-[#00CC07]">chatear.</span>
        </h2>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed">
          ¿No tienes tiempo de abrir una app? Mándale un mensaje o un audio a tu asistente Conty. Él se encarga de registrar todo y darte reportes al instante.
        </p>
        
        <ul class="space-y-4 mb-10">
          <li class="flex items-center gap-3">
            <div class="w-6 h-6 rounded-full bg-[#00CC07]/20 flex items-center justify-center text-[#00CC07]">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="text-gray-700 font-medium">Registra ventas y gastos por voz o texto</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-6 h-6 rounded-full bg-[#00CC07]/20 flex items-center justify-center text-[#00CC07]">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="text-gray-700 font-medium">Pregunta "¿Cuánto vendí hoy?" y obtén respuesta</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-6 h-6 rounded-full bg-[#00CC07]/20 flex items-center justify-center text-[#00CC07]">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="text-gray-700 font-medium">Sincronizado con tu App de Conty</span>
          </li>
        </ul>

        <a
          href="https://wa.me/12013538852?text=%C2%A1Hola!%20Quiero%20tener%20mi%20asistente."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-[#00CC07] text-[#082109] font-bold px-8 py-4 rounded-2xl hover:bg-[#00CC07]/90 transition-all shadow-lg hover:shadow-xl"
        >
          Probar Asistente Gratis
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>

      <div class="flex-1 relative animate-fade-in-right delay-200">
        <!-- WhatsApp UI Mockup -->
        <div class="relative mx-auto w-full max-w-[320px] bg-[#E5DDD5] rounded-[2.5rem] border-[8px] border-[#082109] shadow-2xl overflow-hidden aspect-[9/18]">
          <!-- Header -->
          <div class="bg-[#075E54] p-4 pt-8 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center">
              <img src={contyLogo.src} alt="Conty AI" class="w-8 h-8" />
            </div>
            <div>
              <p class="text-white font-bold text-sm">Conty</p>
              <p class="text-white/70 text-[10px]">En línea</p>
            </div>
          </div>

          <!-- Messages Area -->
          <div class="p-4 space-y-4 h-full overflow-y-auto">
            <!-- User Message -->
            <div class="flex justify-end">
              <div class="bg-[#DCF8C6] p-3 rounded-lg rounded-tr-none shadow-sm max-w-[80%]">
                <p class="text-xs text-gray-800">Vendí 1 Hamburguesa $3.2</p>
                <p class="text-[8px] text-gray-500 text-right mt-1">10:45 AM</p>
              </div>
            </div>

            <!-- Bot Message -->
            <div class="flex justify-start">
              <div class="bg-white p-3 rounded-lg rounded-tl-none shadow-sm max-w-[80%]">
                <p class="text-xs text-gray-800">¡Anotado! ✅ <br/>Venta: Hamburguesa<br/>Monto: $3.20<br/>Tu venta total de hoy es $45.50.</p>
                <p class="text-[8px] text-gray-500 text-right mt-1">10:45 AM</p>
              </div>
            </div>

            <!-- User Message (Audio) -->
            <div class="flex justify-end">
              <div class="bg-[#DCF8C6] p-3 rounded-lg rounded-tr-none shadow-sm max-w-[80%] flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M2 10v3"></path><path d="M6 6v11"></path><path d="M10 3v18"></path><path d="M14 8v7"></path><path d="M18 5v13"></path><path d="M22 10v3"></path></svg>
                <p class="text-[10px] text-gray-600">0:05</p>
                <p class="text-[8px] text-gray-500 text-right mt-1 ml-auto">10:47 AM</p>
              </div>
            </div>

            <!-- Bot Message -->
            <div class="flex justify-start">
              <div class="bg-white p-3 rounded-lg rounded-tl-none shadow-sm max-w-[80%]">
                <p class="text-xs text-gray-800">Entendido. He registrado un gasto de $3.00 en "Papeles". 📋</p>
                <p class="text-[8px] text-gray-500 text-right mt-1">10:47 AM</p>
              </div>
            </div>
            
             <!-- User Message -->
             <div class="flex justify-end">
              <div class="bg-[#DCF8C6] p-3 rounded-lg rounded-tr-none shadow-sm max-w-[80%]">
                <p class="text-xs text-gray-800">¿Cuánto vendí hoy?</p>
                <p class="text-[8px] text-gray-500 text-right mt-1">11:02 AM</p>
              </div>
            </div>

            <!-- Bot Message -->
            <div class="flex justify-start">
              <div class="bg-white p-3 rounded-lg rounded-tl-none shadow-sm max-w-[80%]">
                <p class="text-xs text-gray-800">Hoy llevas <b>$48.50</b> en ventas. Vas muy bien, ¡estás al 85% de tu meta diaria! 🚀</p>
                <p class="text-[8px] text-gray-500 text-right mt-1">11:02 AM</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Decoration -->
        <div class="absolute -z-10 -bottom-10 -right-10 w-64 h-64 bg-[#00CC07]/10 rounded-full blur-3xl"></div>
        <div class="absolute -z-10 -top-10 -left-10 w-48 h-48 bg-[#00CC07]/5 rounded-full blur-2xl"></div>
      </div>
    </div>
  </div>
</section>
