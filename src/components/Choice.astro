---
const { isAppAvailable = false } = Astro.props;
---

<section class="py-16 bg-white border-y border-gray-100">
  <div class="max-w-6xl mx-auto px-5 text-center">
    <div class="animate-fade-in-up">
      <h2 class="text-2xl sm:text-3xl font-bold text-[#082109] mb-4">
        Conty se adapta a tu ritmo
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto mb-12">
        Usa el asistente para el día a día y la app para los detalles. Tú eliges cómo tener el control.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8 text-left">
      <div class="bg-gray-50 p-8 rounded-3xl border border-gray-100 hover:border-[#00CC07]/30 transition-all group animate-fade-in-left delay-100">
        <div class="w-12 h-12 rounded-2xl bg-[#00CC07]/10 flex items-center justify-center text-[#00CC07] mb-6 group-hover:bg-[#00CC07] group-hover:text-white transition-all">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.438 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-[#082109] mb-3">Asistente de WhatsApp</h3>
        <p class="text-gray-500 text-sm mb-4 leading-relaxed">
          Ideal para cuando estás atendiendo clientes. Envía un mensaje rápido y olvida la libreta. ¡Incluso audios!
        </p>
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-[#00CC07]"></div>
          <span class="text-xs font-bold text-[#00CC07] uppercase tracking-wider">Máxima Comodidad</span>
        </div>
      </div>

      <div class="bg-gray-50 p-8 rounded-3xl border border-gray-100 hover:border-[#00CC07]/30 transition-all group animate-fade-in-right delay-200">
        <div class="flex justify-between items-start mb-6">
          <div class="w-12 h-12 rounded-2xl bg-[#00CC07]/10 flex items-center justify-center text-[#00CC07] group-hover:bg-[#00CC07] group-hover:text-white transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
          </div>
          {!isAppAvailable && <span class="bg-gray-200 text-gray-500 text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-tighter">Próximamente</span>}
        </div>
        <h3 class="text-xl font-bold text-[#082109] mb-3">Conty App</h3>
        <p class="text-gray-500 text-sm mb-4 leading-relaxed">
          La experiencia completa. Gráficos detallados, trabajo sin conexión y gestión profunda de tu negocio.
        </p>
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-[#00CC07]"></div>
          <span class="text-xs font-bold text-[#00CC07] uppercase tracking-wider">Control Total</span>
        </div>
      </div>
    </div>
  </div>
</section>
